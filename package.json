{
  "name": "karya",
  "version": "1.0.0",
  "description": "SQL-backed task tracker for AI agent workflows",
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.2.5",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ealt/karya.git"
  },
  "homepage": "https://github.com/ealt/karya#readme",
  "bin": {
    "karya": "./bin/karya"
  },
  "files": [
    "dist/src/",
    "bin/"
  ],
  "exports": {
    ".": "./dist/src/cli/index.js",
    "./core/*": "./dist/src/core/*.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run src/cli/index.ts",
    "dev:node": "node --import tsx src/cli/index.ts",
    "release": "bash scripts/release.sh",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepack": "bun run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "nanoid": "^5.1.5",
    "zod": "^4.1.5"
  },
  "peerDependencies": {
    "pg": "^8.13.1"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
