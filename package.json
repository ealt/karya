{
  "name": "karya",
  "version": "0.1.0",
  "description": "Git-backed task tracker for orchestrating AI agents across machines",
  "type": "module",
  "packageManager": "bun@1.2.5",
  "bin": {
    "karya": "./bin/karya"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run src/cli/index.ts",
    "dev:node": "node --import tsx src/cli/index.ts",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "hono": "^4.12.4",
    "nanoid": "^5.1.5",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.28.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
