#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if command -v bun >/dev/null 2>&1; then
  exec bun run "${PROJECT_ROOT}/src/cli/index.ts" "$@"
fi

exec node --import tsx "${PROJECT_ROOT}/src/cli/index.ts" "$@"
